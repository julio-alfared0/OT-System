@model IEnumerable<OT.Models.Produk>
@using System.Security.Claims
@{
    ViewData["Title"] = "Beranda Eksklusif";
}

<div class="container" style="padding-top: 100px; padding-bottom: 80px;">
        <div class="card hero-dark-card border-0 rounded-5 overflow-hidden mb-5 position-relative shadow-lg" style="background: linear-gradient(135deg, rgba(26, 26, 36, 0.95) 0%, rgba(13, 13, 18, 0.98) 100%); border: 1px solid var(--gold-glow) !important;">
        <div class="position-absolute top-0 end-0 p-5 d-none d-lg-block" style="opacity: 0.12; pointer-events: none;">
            <i class="ph ph-crown" style="font-size: 16rem; color: var(--gold);"></i>
        </div>
        
        <div class="card-body p-4 p-md-5 position-relative z-1 d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-4">
            <div>
                <span class="badge rounded-pill mb-3 px-3 py-2 font-monospace tracking-widest text-uppercase d-inline-flex align-items-center gap-2" style="background: rgba(212, 175, 55, 0.15); color: var(--gold); border: 1px solid rgba(212, 175, 55, 0.3);">
                    <i class="ph ph-shield-star fs-6"></i> Keanggotaan Terverifikasi
                </span>
                <h1 class="fw-bolder mb-2 text-white" style="font-size: clamp(1.8rem, 3.5vw, 2.75rem); letter-spacing: -0.03em;">
                    Selamat Datang, <span class="text-gold">@(User.Identity?.Name ?? "Member Eksekutif")</span>
                </h1>
                <p class="text-muted mb-4" style="max-width: 560px; line-height: 1.6; font-size: 1.05rem;">
                    Nikmati hak istimewa akses ke koleksi mahakarya terbatas dan resep rahasia warisan nusantara yang dijaga ketat sejak abad ke-19.
                </p>
                <div class="d-flex flex-wrap align-items-center gap-3">
                    <a asp-controller="Beranda" asp-action="Katalog" class="btn btn-gold px-4 py-3 rounded-pill fw-bold text-uppercase tracking-wider shadow-sm d-inline-flex align-items-center gap-2" style="color: #000 !important;">
                        <i class="ph ph-wine fs-5"></i> Eksplorasi Koleksi
                    </a>
                    <a asp-controller="Beranda" asp-action="Warisan" class="btn btn-outline-secondary px-4 py-3 rounded-pill fw-semibold text-white d-inline-flex align-items-center gap-2" style="border-color: var(--border-subtle);">
                        <i class="ph ph-scroll fs-5"></i> Sejarah Warisan 1948
                    </a>
                </div>
            </div>

                        <div class="p-4 rounded-4" style="background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-subtle); min-width: 280px; backdrop-filter: blur(16px);">
                <div class="d-flex align-items-center justify-content-between mb-3 border-bottom border-secondary border-opacity-25 pb-3">
                    <span class="text-muted small fw-medium">Status Keanggotaan</span>
                    <span class="badge bg-gold text-dark fw-bold font-monospace px-2 py-1">EKSEKUTIF</span>
                </div>
                <div class="mb-3">
                    <span class="text-muted small d-block mb-1">Poin Kehormatan Loyalitas</span>
                    <h3 class="fw-bold text-gold font-monospace mb-0 d-flex align-items-center gap-2">
                        <i class="ph ph-medal fs-4"></i> 1,948 <span class="fs-6 fw-normal text-muted">Pts</span>
                    </h3>
                </div>
                <div class="d-flex align-items-center justify-content-between small text-muted pt-2 border-top border-secondary border-opacity-25">
                    <span>Distribusi Langsung</span>
                    <span class="text-success fw-semibold"><i class="ph ph-check-circle"></i> Aktif Real-Time</span>
                </div>
            </div>
        </div>
    </div>

        <div class="mb-5">
        <h4 class="fw-bold text-white mb-4 tracking-tight d-flex align-items-center gap-2">
            <i class="ph ph-lightning fs-4 text-gold"></i> Akses Cepat Kehormatan
        </h4>
        <div class="row g-4">
            <div class="col-12 col-sm-6 col-lg-3">
                <a asp-controller="Beranda" asp-action="Katalog" class="card h-100 p-4 rounded-4 text-decoration-none border-0 shadow-sm transition-hover" style="background: var(--surface); border: 1px solid var(--border-subtle) !important;">
                    <div class="d-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 54px; height: 54px; background: rgba(212, 175, 55, 0.15); color: var(--gold);">
                        <i class="ph ph-wine fs-2"></i>
                    </div>
                    <h6 class="fw-bold text-white mb-1">Katalog Lengkap</h6>
                    <p class="text-muted small mb-0">Jelajahi seluruh variasi produk tradisi dan anggur kelas atas kami.</p>
                </a>
            </div>
            <div class="col-12 col-sm-6 col-lg-3">
                <a asp-controller="Checkout" asp-action="Index" class="card h-100 p-4 rounded-4 text-decoration-none border-0 shadow-sm transition-hover" style="background: var(--surface); border: 1px solid var(--border-subtle) !important;">
                    <div class="d-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 54px; height: 54px; background: rgba(54, 162, 235, 0.15); color: #36A2EB;">
                        <i class="ph ph-shopping-bag-open fs-2"></i>
                    </div>
                    <h6 class="fw-bold text-white mb-1">Keranjang & Pesanan</h6>
                    <p class="text-muted small mb-0">Pantau transaksi dan proses penyelesaian pengiriman barang Anda.</p>
                </a>
            </div>
            <div class="col-12 col-sm-6 col-lg-3">
                <a asp-controller="Beranda" asp-action="Warisan" class="card h-100 p-4 rounded-4 text-decoration-none border-0 shadow-sm transition-hover" style="background: var(--surface); border: 1px solid var(--border-subtle) !important;">
                    <div class="d-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 54px; height: 54px; background: rgba(255, 159, 64, 0.15); color: #FF9F40;">
                        <i class="ph ph-scroll fs-2"></i>
                    </div>
                    <h6 class="fw-bold text-white mb-1">Warisan Leluhur</h6>
                    <p class="text-muted small mb-0">Baca kisah sejarah dan filosofi di balik peracikan ramuan 1948.</p>
                </a>
            </div>
            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card h-100 p-4 rounded-4 border-0 shadow-sm transition-hover" style="background: var(--surface); border: 1px solid var(--border-subtle) !important; cursor: pointer;" onclick="document.getElementById('open-cmd-palette').click();">
                    <div class="d-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 54px; height: 54px; background: rgba(153, 102, 255, 0.15); color: #9966FF;">
                        <i class="ph ph-magnifying-glass fs-2"></i>
                    </div>
                    <h6 class="fw-bold text-white mb-1">Pencarian Cepat</h6>
                    <p class="text-muted small mb-0">Gunakan Command Palette (Ctrl + K) untuk melompat seketika ke produk.</p>
                </div>
            </div>
        </div>
    </div>

        @if (Model != null && Model.Any())
    {
        <div class="mb-5">
            <div class="d-flex justify-content-between align-items-end mb-4">
                <div>
                    <span class="text-gold small fw-bold font-monospace tracking-widest text-uppercase d-block mb-1">Sorotan Kehormatan</span>
                    <h3 class="fw-bold text-white mb-0">Mahakarya Unggulan</h3>
                </div>
                <a asp-controller="Beranda" asp-action="Katalog" class="btn btn-link text-gold text-decoration-none small fw-bold d-flex align-items-center gap-1">
                    Lihat Semua Koleksi <i class="ph ph-arrow-right"></i>
                </a>
            </div>

            <div class="row g-4">
                @foreach (var item in Model.Take(4))
                {
                    <div class="col-12 col-md-6 col-lg-3">
                        <div class="card h-100 border-0 rounded-4 overflow-hidden position-relative transition-hover" style="background: var(--surface); border: 1px solid var(--border-subtle) !important;">
                            <div class="p-4 d-flex justify-content-center align-items-center position-relative" style="height: 250px; background: radial-gradient(circle at center, rgba(212,175,55,0.08) 0%, transparent 70%);">
                                @if (item.Stok == 0)
                                {
                                    <span class="position-absolute top-0 end-0 m-3 badge bg-danger bg-opacity-75 text-white font-monospace small px-2 py-1" style="z-index: 2;">HABIS</span>
                                }
                                else if (item.Stok < 10)
                                {
                                    <span class="position-absolute top-0 end-0 m-3 badge bg-warning bg-opacity-75 text-dark font-monospace small px-2 py-1" style="z-index: 2;">TERBATAS</span>
                                }
                                <img src="@(item.JalurGambar?.Replace("/assets/image/", "/assets/webp/").Replace("/OT-Product/webp/", "/assets/webp/"))" alt="@item.NamaProduk" class="img-fluid transition-scale" style="max-height: 100%; object-fit: contain;" />
                            </div>
                            
                            <div class="card-body p-4 d-flex flex-column justify-content-between">
                                <div>
                                    <span class="badge bg-secondary bg-opacity-25 text-gold small font-monospace px-2 py-0 mb-2">@(item.Kategori?.NamaKategori ?? "Warisan")</span>
                                    <h5 class="fw-bold text-white mb-2">@item.NamaProduk</h5>
                                    <p class="text-muted small line-clamp-2 mb-3">@item.Deskripsi</p>
                                </div>
                                
                                <div class="d-flex align-items-center justify-content-between pt-3 border-top border-secondary border-opacity-25">
                                    <div>
                                        <span class="text-muted small d-block" style="font-size: 0.75rem;">Nilai Investasi</span>
                                        <span class="fw-bold text-gold font-monospace">Rp @item.Harga.ToString("N0")</span>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <a asp-controller="Beranda" asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3 py-2 fw-semibold text-main d-flex align-items-center gap-1" style="border-color: var(--border-subtle);">
                                            Detail
                                        </a>
                                        @if (!User.IsInRole("Admin") && !User.HasClaim(ClaimTypes.Role, "Admin"))
                                        {
                                            <button type="button" class="btn btn-sm btn-gold rounded-pill px-3 py-2 fw-bold text-dark d-flex align-items-center gap-1 btn-tambah-keranjang" data-id="@item.Id" title="Tambah ke Keranjang">
                                                <i class="ph ph-shopping-cart-plus"></i>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

        @if (ViewBag.ProdukRiwayat != null)
    {
        var riwayat = ViewBag.ProdukRiwayat as IEnumerable<OT.Models.Produk>;
        if (riwayat != null && riwayat.Any())
        {
            <div class="mb-5 pt-4 border-top border-secondary border-opacity-25">
                <h4 class="mb-4 fw-bold text-white d-flex align-items-center gap-2">
                    <i class="ph ph-clock-counter-clockwise fs-5 text-gold"></i> Terakhir Anda Eksplorasi
                </h4>
                <div class="row g-4">
                    @foreach(var item in riwayat)
                    {
                        <div class="col-6 col-md-3">
                            <a asp-controller="Beranda" asp-action="Detail" asp-route-id="@item.Id" class="card bg-dark text-white border-0 rounded-4 overflow-hidden h-100 text-decoration-none transition-hover" style="background: rgba(255,255,255,0.04) !important; border: 1px solid var(--border-subtle) !important;">
                                <div class="p-3 d-flex justify-content-center align-items-center" style="height: 180px;">
                                    <img src="@(item.JalurGambar?.Replace("/assets/image/", "/assets/webp/").Replace("/OT-Product/webp/", "/assets/webp/"))" alt="@item.NamaProduk" class="img-fluid" style="max-height: 100%; object-fit: contain;">
                                </div>
                                <div class="card-body p-3 text-center">
                                    <h6 class="fw-bold mb-1 text-white">@item.NamaProduk</h6>
                                    <small class="text-gold font-monospace">Rp @item.Harga.ToString("N0")</small>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

<style>
    .transition-hover {
        transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .transition-hover:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-lg), 0 0 32px var(--gold-glow);
        border-color: var(--gold) !important;
    }
    .transition-scale {
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .transition-hover:hover .transition-scale {
        transform: scale(1.08);
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.btn-tambah-keranjang').click(function(e) {
                e.preventDefault(); 
                e.stopPropagation(); 
                
                var btn = $(this);
                var produkId = btn.data('id');
                var originalIcon = btn.html();
                
                btn.html('<i class="ph ph-spinner ph-spin fs-5"></i>');
                
                $.post('/Keranjang/Tambah', { produkId: produkId }, function(response) {
                    if (response.sukses) {
                        btn.html('<i class="ph ph-check text-success fs-5"></i>');
                        
                        if (typeof window.updateCartBadge === 'function') {
                            window.updateCartBadge();
                        } else {
                            var badge = $('#cart-badge');
                            var current = parseInt(badge.text());
                            if (isNaN(current)) current = 0;
                            badge.text(current + 1);
                        }
                        
                        setTimeout(function() {
                            btn.html(originalIcon);
                        }, 2000);
                    } else {
                        alert(response.pesan);
                        btn.html(originalIcon);
                    }
                }).fail(function() {
                    alert("Terjadi kesalahan sistem, silakan coba lagi.");
                    btn.html(originalIcon);
                });
            });
        });
    </script>
}

