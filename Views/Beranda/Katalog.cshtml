@model IEnumerable<OT.Models.Produk>
@{
    ViewData["Title"] = "Katalog Produk";
}

<div class="container" style="padding-top: 100px; padding-bottom: 60px;">
    
    <div class="text-center mb-5">
        <h2 class="display-5 fw-bold mb-3 text-main">Katalog Mahakarya</h2>
        <p class="text-muted">Pilih warisan rasa terbaik untuk melengkapi momen berharga Anda.</p>
    </div>

    @if (ViewBag.ProdukRiwayat != null)
    {
        var riwayat = ViewBag.ProdukRiwayat as IEnumerable<OT.Models.Produk>;
        if (riwayat != null && riwayat.Any())
        {
            <div class="mb-5">
                <h4 class="mb-4 fw-bold text-main d-flex align-items-center gap-2">
                    <i class="ph ph-clock-counter-clockwise fs-5 text-gold"></i> Terakhir Dilihat
                </h4>
                <div class="row g-4">
                    @foreach(var item in riwayat)
                    {
                        <div class="col-6 col-md-3">
                            <div class="card product-card text-main border-0 rounded-4 overflow-hidden h-100 bg-surface">
                                <div class="p-4 d-flex justify-content-center align-items-center" style="height: 200px;">
                                    <img src="@(item.JalurGambar?.Replace("/assets/image/", "/assets/webp/").Replace("/OT-Product/webp/", "/assets/webp/"))" alt="@item.NamaProduk" class="img-fluid" style="max-height: 100%; object-fit: contain;">
                                </div>
                                <div class="card-body p-3 text-center">
                                    <h6 class="fw-bold mb-1 text-main">@item.NamaProduk</h6>
                                    <small class="text-gold">Rp @item.Harga.ToString("N0")</small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }

        <div class="bento-grid">
        @foreach (var item in Model)
        {
            <div class="bento-card">
                <div class="bento-img-container">
                    <img src="@(item.JalurGambar?.Replace("/assets/image/", "/assets/webp/").Replace("/OT-Product/webp/", "/assets/webp/"))" alt="@item.NamaProduk" class="bento-img" loading="lazy" />
                </div>
                
                <div class="bento-overlay">
                    <div class="d-flex justify-content-between align-items-end">
                        <div class="flex-grow-1 pe-3">
                            <h3 class="bento-title">@item.NamaProduk</h3>
                            <p class="bento-desc">@item.Deskripsi</p>
                            <div class="bento-price">Rp @item.Harga.ToString("N0")</div>
                        </div>
                        <div>
                            @if (item.Stok > 0)
                            {
                                <button class="btn btn-add-cart btn-tambah-keranjang d-flex align-items-center justify-content-center" data-id="@item.Id" title="Tambah ke Keranjang">
                                    <i class="ph ph-plus fs-5"></i>
                                </button>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-75 text-white px-2 py-1 font-monospace small" style="backdrop-filter: blur(4px);">
                                    STOK HABIS
                                </span>
                            }
                        </div>
                    </div>
                    <div class="mt-2 text-muted d-flex align-items-center gap-2" style="font-size: 0.75rem;">
                        <span><i class="ph ph-wine fs-6"></i> @item.PersentaseAlkohol% | @item.VolumeML ML</span>
                        @if (item.Stok > 0 && item.Stok < 10)
                        {
                            <span class="text-warning fw-bold">(Sisa @item.Stok Unit)</span>
                        }
                    </div>
                </div>
                                <a asp-action="Detail" asp-route-id="@item.Id" class="position-absolute top-0 start-0 w-100 h-100" style="z-index: 1;"></a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.btn-tambah-keranjang').click(function(e) {
                e.preventDefault(); 
                e.stopPropagation(); 
                
                var btn = $(this);
                var produkId = btn.data('id');
                var originalIcon = btn.html();
                
                btn.html('<i class="ph ph-spinner ph-spin fs-5"></i>');
                
                $.post('/Keranjang/Tambah', { produkId: produkId }, function(response) {
                    if (response.sukses) {
                        btn.html('<i class="ph ph-check text-success fs-5"></i>');
                        
                        if (typeof window.updateCartBadge === 'function') {
                            window.updateCartBadge();
                        } else {
                            var badge = $('#cart-badge');
                            var current = parseInt(badge.text());
                            if (isNaN(current)) current = 0;
                            badge.text(current + 1);
                        }
                        
                        setTimeout(function() {
                            btn.html(originalIcon);
                        }, 2000);
                    } else {
                        alert(response.pesan);
                        btn.html(originalIcon);
                    }
                }).fail(function() {
                    alert("Terjadi kesalahan sistem, silakan coba lagi.");
                    btn.html(originalIcon);
                });
            });
            
            $('.btn-add-cart').css('position', 'relative').css('z-index', '5');
        });
    </script>
}
