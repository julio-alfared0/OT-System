@{
    ViewData["Title"] = "Warisan Leluhur 1948";
}

<div class="container" style="padding-top: 110px; padding-bottom: 90px;">
        <div class="text-center mb-5 pb-3">
        <span class="badge rounded-pill px-3 py-2 font-monospace tracking-widest text-uppercase mb-3" style="background: rgba(212, 175, 55, 0.15); color: var(--gold); border: 1px solid rgba(212, 175, 55, 0.3);">
            Tradisi & Presisi Abadi
        </span>
        <h1 class="fw-bolder mb-3 text-main display-4 tracking-tight">Kisah Warisan 1948</h1>
        <p class="text-muted mx-auto" style="max-width: 640px; line-height: 1.7; font-size: 1.1rem;">
            Menjaga resep rahasia warisan leluhur demi mempersembahkan cita rasa taktil berkelas dunia. Nikmati kemewahan dan keaslian dalam setiap tetesnya.
        </p>
    </div>

        <div class="card border-0 rounded-5 overflow-hidden mb-5 shadow-lg position-relative" style="background: var(--surface); border: 1px solid var(--border-subtle) !important;">
        <div class="row g-0 align-items-center">
            <div class="col-12 col-lg-6">
                <div class="p-5 d-flex flex-column justify-content-center h-100">
                    <span class="text-gold font-monospace small tracking-widest text-uppercase mb-2">Filosofi Penyulingan</span>
                    <h2 class="fw-bold text-main mb-3">Seni Peracikan Sejak Abad Ke-19</h2>
                    <p class="text-muted mb-4" style="line-height: 1.7;">
                        Bermula dari perpaduan rempah-rempah pilihan dari seluruh penjuru nusantara dengan teknik penyulingan presisi yang diwariskan secara turun-temurun sejak tahun 1948. Kami tidak sekadar memproduksi minuman, melainkan menjaga warisan identitas dan kehormatan budaya.
                    </p>
                    <div class="d-flex align-items-center gap-4 pt-3 border-top border-secondary border-opacity-25">
                        <div>
                            <h4 class="fw-bold text-gold font-monospace mb-0">100%</h4>
                            <span class="text-muted small">Bahan Alami Pilihan</span>
                        </div>
                        <div class="border-start border-secondary border-opacity-25 ps-4">
                            <h4 class="fw-bold text-gold font-monospace mb-0">76+ Tahun</h4>
                            <span class="text-muted small">Dedikasi Konsisten</span>
                        </div>
                        <div class="border-start border-secondary border-opacity-25 ps-4">
                            <h4 class="fw-bold text-gold font-monospace mb-0">ISO 9001</h4>
                            <span class="text-muted small">Standar Mutu Dunia</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-6">
                <div class="position-relative overflow-hidden h-100" style="min-height: 380px;">
                    <img src="/assets/image/iceland.webp" alt="Penyulingan Warisan 1948" class="position-absolute inset-0 w-100 h-100" style="object-fit: cover; filter: brightness(0.8) contrast(1.15);" />
                </div>
            </div>
        </div>
    </div>

        <div class="row g-4 mb-5">
        <div class="col-12 col-md-4">
            <div class="card h-100 p-4 rounded-4 border-0 shadow-sm" style="background: var(--surface); border: 1px solid var(--border-subtle) !important;">
                <div class="badge bg-gold text-dark fw-bold font-monospace mb-3 w-auto d-inline-block px-3 py-2">TAHUN 1948</div>
                <h5 class="fw-bold text-main mb-2">Awal Mula Titik Kumpul</h5>
                <p class="text-muted small mb-0" style="line-height: 1.6;">
                    Perumusan resep anggur obat tradisional dan spirits ramuan pertama kali dipatenkan untuk kalangan eksklusif dan bangsawan.
                </p>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card h-100 p-4 rounded-4 border-0 shadow-sm" style="background: var(--surface); border: 1px solid var(--border-subtle) !important;">
                <div class="badge bg-gold text-dark fw-bold font-monospace mb-3 w-auto d-inline-block px-3 py-2">TAHUN 1985</div>
                <h5 class="fw-bold text-main mb-2">Modernisasi & Ekspansi</h5>
                <p class="text-muted small mb-0" style="line-height: 1.6;">
                    Penerapan teknologi fermentasi modern tanpa menghilangkan keaslian rasa dan khasiat alami yang telah diakui secara global.
                </p>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card h-100 p-4 rounded-4 border-0 shadow-sm" style="background: var(--surface); border: 1px solid var(--border-subtle) !important;">
                <div class="badge bg-gold text-dark fw-bold font-monospace mb-3 w-auto d-inline-block px-3 py-2">MASA KINI</div>
                <h5 class="fw-bold text-main mb-2">Platform Digital Eksklusif</h5>
                <p class="text-muted small mb-0" style="line-height: 1.6;">
                    Transformasi menuju distribusi digital eksklusif (Tactile Luxury) bagi member terverifikasi di seluruh nusantara dan dunia.
                </p>
            </div>
        </div>
    </div>

    <div class="text-center pt-4">
        <a asp-controller="Beranda" asp-action="Katalog" class="btn btn-gold px-5 py-3 rounded-pill fw-bold text-uppercase tracking-wider shadow-lg d-inline-flex align-items-center gap-2" style="color: #000 !important;">
            <i class="ph ph-wine fs-5"></i> Eksplorasi Koleksi Sekarang
        </a>
    </div>
</div>
