@model OT.ViewModels.VerifikasiOtpViewModel
@{
    ViewData["Title"] = "Verifikasi OTP";
    Layout = null;
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verifikasi OTP - Warisan 1948</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
        <script src="https://unpkg.com/@@phosphor-icons/web@2.1.1"></script>
    <link rel="stylesheet" href="~/css/style.css" />
    <script>
        (function() {
            var savedTheme = localStorage.getItem("ot-theme") || "dark";
            document.documentElement.setAttribute("data-theme", savedTheme);
        })();
    </script>
</head>
<body style="background: var(--bg-onyx); color: var(--text-main); font-family: 'Inter', system-ui, -apple-system, sans-serif;">
    <div class="split-screen min-vh-100">
        <div class="split-image position-relative" 
             style="background-image: url('/assets/image/codingo.webp');">
            <div class="position-absolute inset-0 w-100 h-100 d-flex flex-column justify-content-end p-4 p-md-5" 
                 style="background: linear-gradient(180deg, rgba(9,9,11,0.15) 0%, rgba(9,9,11,0.88) 100%);">
                <span class="badge mb-3 px-3 py-2 rounded-pill font-monospace small tracking-widest text-uppercase d-inline-flex align-items-center gap-2" style="background: rgba(212, 175, 55, 0.15); color: var(--gold); border: 1px solid rgba(212, 175, 55, 0.3); width: fit-content;">
                    <i class="ph ph-shield-check fs-6"></i> Verifikasi Ganda
                </span>
                <h3 class="fw-bolder text-white mb-2" style="font-size: clamp(1.6rem, 2.2vw, 2.1rem); letter-spacing: -0.03em;">Keamanan Tingkat Tinggi</h3>
                <p class="text-muted small mb-0" style="line-height: 1.6;">Kode rahasia sekali pakai untuk memastikan otentikasi identitas yang sah.</p>
            </div>
        </div>
        <div class="split-form">
            <div style="width: 100%; max-width: 460px; margin: auto;">
                <div class="text-center mb-5">
                    <img src="/assets/logo/OT1948.webp" alt="OT Logo" class="mb-4" style="max-width: 60px; height: auto; filter: invert(1); opacity: 0.9;" />
                    <h2 class="fw-bold text-white mb-2 tracking-tight">Verifikasi Identitas</h2>
                    <p class="text-light small" style="opacity: 0.85;">Kami telah mengirimkan 6-digit kode OTP ke email Anda.</p>
                </div>
                
                @if(TempData["AlertOtp"] != null)
                {
                    <div class="alert alert-warning bg-transparent border-warning text-warning text-center small py-3 mb-4 rounded-3 d-flex align-items-center justify-content-center gap-2">
                        <i class="ph ph-bell-ringing fs-5"></i> @TempData["AlertOtp"]
                    </div>
                }

                <form asp-action="VerifikasiOtp" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 text-center small"></div>
                    <input type="hidden" asp-for="Email" />
                    
                    <div class="mb-4">
                        <label asp-for="KodeOtp" class="form-label text-light small fw-semibold">Kode Keamanan OTP</label>
                        <input asp-for="KodeOtp" class="form-control form-control-dark text-center font-monospace rounded-3 py-3 fs-4 tracking-widest" placeholder="• • • • • •" maxlength="6" />
                        <span asp-validation-for="KodeOtp" class="text-danger small mt-1 d-block text-center"></span>
                    </div>

                    <button type="submit" class="btn btn-gold w-100 py-3 rounded-pill mb-4 shadow-lg tracking-wider text-uppercase small fw-bold">Verifikasi & Lanjutkan</button>
                    
                    <div class="text-center text-light small">
                        Belum menerima kode? 
                        <a asp-action="LupaKataSandi" class="text-gold fw-bold text-decoration-none border-bottom border-secondary ms-1">Kirim Ulang</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
