@model OT.ViewModels.DaftarViewModel
@{
    ViewData["Title"] = "Pendaftaran Keanggotaan Warisan 1948";
    Layout = null;
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Daftar - Warisan 1948</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
        <script src="https://unpkg.com/@@phosphor-icons/web@2.1.1"></script>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
        <link rel="stylesheet" href="~/css/style.css" />
        <script>
            (function() {
                var savedTheme = localStorage.getItem("ot-theme") || "dark";
                document.documentElement.setAttribute("data-theme", savedTheme);
            })();
        </script>
</head>
<body style="background: var(--bg-main); color: var(--text-main); font-family: 'Inter', system-ui, -apple-system, sans-serif;">
    <div class="split-screen min-vh-100">
        <div class="split-image position-relative overflow-hidden" style="border-radius: clamp(24px, 2.5vw, 36px); border: 1px solid var(--gold-glow); box-shadow: var(--shadow-lg);">
            <div class="auth-slider-container position-absolute inset-0 w-100 h-100 overflow-hidden">
                <div class="auth-slide position-absolute inset-0 w-100 h-100" style="background-image: url('/assets/image/blueagave.webp'); background-size: cover; background-position: center; filter: brightness(0.72) contrast(1.1) saturate(1.15); opacity: 1; transform: scale(1.08);"></div>
                <div class="auth-slide position-absolute inset-0 w-100 h-100" style="background-image: url('/assets/image/iceland.webp'); background-size: cover; background-position: center; filter: brightness(0.72) contrast(1.1) saturate(1.15); opacity: 0; transform: scale(1.08);"></div>
                <div class="auth-slide position-absolute inset-0 w-100 h-100" style="background-image: url('/assets/image/manta-.webp'); background-size: cover; background-position: center; filter: brightness(0.72) contrast(1.1) saturate(1.15); opacity: 0; transform: scale(1.08);"></div>
            </div>
            <div class="position-absolute inset-0 w-100 h-100 d-flex flex-column justify-content-end p-4 p-md-5" 
                 style="background: radial-gradient(circle at 30% 70%, transparent 0%, rgba(9,9,11,0.65) 100%), linear-gradient(180deg, rgba(9,9,11,0.15) 0%, rgba(9,9,11,0.95) 100%); z-index: 2; pointer-events: none;">
                <span class="badge mb-3 px-3 py-2 rounded-pill font-monospace small tracking-widest text-uppercase d-inline-flex align-items-center gap-2" style="background: rgba(212, 175, 55, 0.18); color: var(--gold); border: 1px solid rgba(212, 175, 55, 0.35); width: fit-content; backdrop-filter: blur(10px);">
                    <i class="ph ph-shield-check fs-6"></i> Keaslian Terjamin
                </span>
                <h3 class="fw-bolder text-white mb-2" style="font-size: clamp(1.6rem, 2.2vw, 2.1rem); letter-spacing: -0.03em;">Bergabunglah dengan Kehormatan</h3>
                <p class="text-white-50 small mb-0" style="line-height: 1.6;">Platform eksklusif yang dikhususkan bagi penikmat tradisi nusantara berusia 21 tahun ke atas.</p>
            </div>
        </div>
        
                <div class="split-form">
            <div style="width: 100%; max-width: 480px; margin: auto;">
                <div class="text-center mb-4">
                    <img src="/assets/logo/OT1948.webp" alt="OT 1948 Logo" class="mb-4 theme-invert-logo" style="max-width: 80px; height: auto; opacity: 0.9;" />
                    <h2 class="fw-bold text-main mb-2 tracking-tight" style="font-size: 2rem;">Jadilah Bagian dari Kami</h2>
                    <p class="text-muted small">Lengkapi verifikasi usia dan identitas diri Anda di bawah ini.</p>
                </div>
                
                @if(TempData["PesanError"] != null)
                {
                    <div class="alert alert-danger bg-transparent border-danger text-danger text-center mb-4 small py-2 rounded-3 d-flex align-items-center justify-content-center gap-2">
                        <i class="ph ph-warning-circle fs-5"></i> @TempData["PesanError"]
                    </div>
                }

                <form asp-action="Daftar" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 text-center small"></div>
                    
                    <div class="mb-3">
                        <label asp-for="NamaLengkap" class="form-label text-main small fw-semibold">Nama Lengkap</label>
                        <input asp-for="NamaLengkap" class="form-control form-control-dark rounded-3 py-3 shadow-sm" placeholder="Masukkan nama lengkap resmi Anda..." autocomplete="name" />
                        <span asp-validation-for="NamaLengkap" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-6">
                            <label asp-for="Email" class="form-label text-main small fw-semibold">Alamat Email</label>
                            <input asp-for="Email" class="form-control form-control-dark rounded-3 py-3 shadow-sm" placeholder="alamat.email@domain.com" autocomplete="email" />
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-12 col-md-6">
                            <label asp-for="NamaPengguna" class="form-label text-main small fw-semibold">Nama Pengguna</label>
                            <input asp-for="NamaPengguna" class="form-control form-control-dark rounded-3 py-3 shadow-sm" placeholder="Masukkan nama pengguna unik..." autocomplete="username" />
                            <span asp-validation-for="NamaPengguna" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-6">
                            <label asp-for="KataSandi" class="form-label text-main small fw-semibold">Kata Sandi</label>
                            <div class="input-group d-flex align-items-center form-control-dark p-0 overflow-hidden shadow-sm" style="border-radius: 12px; transition: all 0.3s ease;">
                                <input asp-for="KataSandi" class="form-control bg-transparent border-0 text-main px-3 py-3" style="box-shadow: none;" placeholder="Minimal 6 karakter" autocomplete="new-password" />
                                <span class="px-3 toggle-password d-flex align-items-center justify-content-center" style="cursor: pointer; color: var(--text-muted);">
                                    <i class="ph ph-eye-slash fs-5"></i>
                                </span>
                            </div>
                            <span asp-validation-for="KataSandi" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-12 col-md-6">
                            <label asp-for="KonfirmasiKataSandi" class="form-label text-main small fw-semibold">Konfirmasi Sandi</label>
                            <div class="input-group d-flex align-items-center form-control-dark p-0 overflow-hidden shadow-sm" style="border-radius: 12px; transition: all 0.3s ease;">
                                <input asp-for="KonfirmasiKataSandi" class="form-control bg-transparent border-0 text-main px-3 py-3" style="box-shadow: none;" placeholder="Ulangi sandi" autocomplete="new-password" />
                                <span class="px-3 toggle-password d-flex align-items-center justify-content-center" style="cursor: pointer; color: var(--text-muted);">
                                    <i class="ph ph-eye-slash fs-5"></i>
                                </span>
                            </div>
                            <span asp-validation-for="KonfirmasiKataSandi" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                                        <div class="mb-4">
                        <label asp-for="TanggalLahir" class="form-label text-gold small fw-bold d-flex align-items-center gap-1">
                            <i class="ph ph-calendar-check fs-6"></i> Tanggal Lahir (Wajib Usia 21+ Tahun)
                        </label>
                        <div class="input-group d-flex align-items-center form-control-dark p-0 overflow-hidden shadow-sm" style="border-radius: 14px; cursor: pointer; transition: all 0.3s ease;">
                            <span class="px-3 d-flex align-items-center justify-content-center text-gold" id="btn-open-calendar">
                                <i class="ph ph-calendar-blank fs-5"></i>
                            </span>
                            <input asp-for="TanggalLahir" type="text" id="datepicker-luxury" class="form-control bg-transparent border-0 text-main px-2 py-3 font-monospace" style="box-shadow: none; cursor: pointer;" placeholder="Pilih Tanggal (DD / MM / YYYY)" readonly />
                        </div>
                        <span asp-validation-for="TanggalLahir" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4 form-check d-flex align-items-start gap-2">
                        <input type="checkbox" id="persetujuan" class="form-check-input mt-1 shadow-sm" style="cursor: pointer; border-color: var(--border-subtle);" required>
                        <label for="persetujuan" class="form-check-label text-muted small" style="cursor: pointer; line-height: 1.5;">
                            Saya menyatakan dengan jujur dan sah bahwa saya telah berusia minimal 21 tahun serta menyetujui Syarat & Ketentuan Distribusi Resmi Produk Orang Tua 1948.
                        </label>
                    </div>

                    <button type="submit" class="btn btn-gold w-100 py-3 rounded-pill mb-4 shadow-lg tracking-wider text-uppercase small fw-bold d-flex align-items-center justify-content-center gap-2" style="color: #000;">
                        <i class="ph ph-user-plus fs-5"></i> Daftar Akun Baru
                    </button>
                    
                    <div class="text-center text-muted small">
                        Sudah memiliki akses ke sistem? 
                        <a asp-action="Masuk" class="text-main fw-bold text-decoration-none ms-1" style="border-bottom: 1px solid var(--text-main);">Masuk ke Sistem</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
        <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://npmcdn.com/flatpickr/dist/l10n/id.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script>
        $(document).ready(function() {
            if ($.validator) {
                $.validator.setDefaults({ ignore: [] });
            }
            $('.toggle-password').click(function() {
                var icon = $(this).find('i');
                var input = $(this).siblings('input');
                if (input.attr('type') === 'password' || !input.attr('type')) {
                    input.attr('type', 'text');
                    icon.removeClass('ph-eye-slash').addClass('ph-eye');
                } else {
                    input.attr('type', 'password');
                    icon.removeClass('ph-eye').addClass('ph-eye-slash');
                }
            });

            $('input[name="KataSandi"], input[name="KonfirmasiKataSandi"]').on('focus', function() {
                $(this).closest('.input-group').css({
                    'border-color': 'var(--gold)',
                    'background': 'var(--surface-hover)',
                    'box-shadow': '0 4px 20px rgba(212, 175, 55, 0.22)'
                });
            }).on('blur', function() {
                $(this).closest('.input-group').css({
                    'border-color': 'var(--border-subtle)',
                    'background': 'var(--surface)',
                    'box-shadow': 'var(--shadow-sm)'
                });
            });
            
            const isDark = document.documentElement.getAttribute("data-theme") !== "light";
            if(isDark) {
                $('.theme-invert-logo').css('filter', 'invert(1)');
            }

            var max21Year = new Date();
            max21Year.setFullYear(max21Year.getFullYear() - 21);

            var fp = flatpickr("#datepicker-luxury", {
                locale: "id",
                dateFormat: "Y-m-d",
                altInput: true,
                altFormat: "d F Y",
                defaultDate: max21Year,
                maxDate: max21Year,
                disableMobile: true,
                onReady: function(selectedDates, dateStr, instance) {
                    $(instance.calendarContainer).addClass('luxury-onyx-theme');
                },
                onOpen: function(selectedDates, dateStr, instance) {
                    $(instance.calendarContainer).addClass('luxury-onyx-theme');
                    if (typeof gsap !== 'undefined') {
                        gsap.fromTo(instance.calendarContainer, 
                            { opacity: 0, scale: 0.94, y: -12 }, 
                            { opacity: 1, scale: 1, y: 0, duration: 0.35, ease: "expo.out" }
                        );
                    }
                }
            });

            $('#btn-open-calendar').click(function(e) {
                e.preventDefault();
                fp.open();
            });

            if (typeof gsap !== 'undefined') {
                const slides = document.querySelectorAll(".auth-slide");
                if (slides.length > 0) {
                    let currentSlide = 0;

                    slides.forEach((slide, index) => {
                        gsap.to(slide, {
                            scale: 1.15,
                            duration: 12,
                            repeat: -1,
                            yoyo: true,
                            ease: "sine.inOut",
                            delay: index * 2
                        });
                    });

                    setInterval(() => {
                        const nextSlide = (currentSlide + 1) % slides.length;

                        gsap.to(slides[currentSlide], {
                            opacity: 0,
                            duration: 1.8,
                            ease: "power2.inOut"
                        });

                        gsap.to(slides[nextSlide], {
                            opacity: 1,
                            duration: 1.8,
                            ease: "power2.inOut"
                        });

                        currentSlide = nextSlide;
                    }, 6500);

                    document.addEventListener("mousemove", (e) => {
                        if (window.innerWidth >= 992) {
                            const x = (window.innerWidth / 2 - e.pageX) / 70;
                            const y = (window.innerHeight / 2 - e.pageY) / 70;
                            gsap.to(".auth-slider-container", {
                                x: x,
                                y: y,
                                duration: 1.2,
                                ease: "power2.out"
                            });
                        }
                    });
                }
            }
        });
    </script>
</body>
</html>
