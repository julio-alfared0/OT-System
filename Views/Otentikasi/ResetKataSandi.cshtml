@model OT.ViewModels.ResetKataSandiViewModel
@{
    ViewData["Title"] = "Atur Ulang Kata Sandi";
    Layout = null;
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Atur Ulang Sandi - Warisan 1948</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
        <script src="https://unpkg.com/@@phosphor-icons/web@2.1.1"></script>
    <link rel="stylesheet" href="~/css/style.css" />
    <script>
        (function() {
            var savedTheme = localStorage.getItem("ot-theme") || "dark";
            document.documentElement.setAttribute("data-theme", savedTheme);
        })();
    </script>
</head>
<body style="background: var(--bg-onyx); color: var(--text-main); font-family: 'Inter', system-ui, -apple-system, sans-serif;">
    <div class="split-screen min-vh-100">
        <div class="split-image position-relative" 
             style="background-image: url('/assets/image/mazemaze.webp');">
            <div class="position-absolute inset-0 w-100 h-100 d-flex flex-column justify-content-end p-4 p-md-5" 
                 style="background: linear-gradient(180deg, rgba(9,9,11,0.15) 0%, rgba(9,9,11,0.88) 100%);">
                <span class="badge mb-3 px-3 py-2 rounded-pill font-monospace small tracking-widest text-uppercase d-inline-flex align-items-center gap-2" style="background: rgba(212, 175, 55, 0.15); color: var(--gold); border: 1px solid rgba(212, 175, 55, 0.3); width: fit-content;">
                    <i class="ph ph-shield-check fs-6"></i> Pembaruan Sesi
                </span>
                <h3 class="fw-bolder text-white mb-2" style="font-size: clamp(1.6rem, 2.2vw, 2.1rem); letter-spacing: -0.03em;">Keamanan Kredensial</h3>
                <p class="text-muted small mb-0" style="line-height: 1.6;">Pastikan kata sandi baru Anda unik dan kuat demi perlindungan maksimal atas data transaksi Anda.</p>
            </div>
        </div>
        <div class="split-form">
            <div style="width: 100%; max-width: 460px; margin: auto;">
                <div class="text-center mb-5">
                    <img src="/assets/logo/OT1948.webp" alt="OT Logo" class="mb-4" style="max-width: 60px; height: auto; filter: invert(1); opacity: 0.9;" />
                    <h2 class="fw-bold text-white mb-2 tracking-tight">Kata Sandi Baru</h2>
                    <p class="text-light small" style="opacity: 0.85;">Buat kata sandi baru untuk mengamankan kembali sesi dan data transaksi Anda.</p>
                </div>
                
                <form asp-action="ResetKataSandi" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 text-center small"></div>
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="KodeOtp" />
                    
                    <div class="mb-4">
                        <label asp-for="KataSandiBaru" class="form-label text-light small fw-semibold">Kata Sandi Baru</label>
                        <div class="input-group d-flex align-items-center form-control-dark p-0 overflow-hidden" style="border-radius: 12px;">
                            <input asp-for="KataSandiBaru" class="form-control bg-transparent border-0 text-white px-3 py-3" style="box-shadow: none;" placeholder="Minimal 6 karakter" autocomplete="new-password" />
                            <span class="px-3 toggle-password d-flex align-items-center justify-content-center" style="cursor: pointer; color: var(--text-muted);">
                                <i class="ph ph-eye-slash fs-5"></i>
                            </span>
                        </div>
                        <span asp-validation-for="KataSandiBaru" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="KonfirmasiKataSandiBaru" class="form-label text-light small fw-semibold">Konfirmasi Kata Sandi Baru</label>
                        <div class="input-group d-flex align-items-center form-control-dark p-0 overflow-hidden" style="border-radius: 12px;">
                            <input asp-for="KonfirmasiKataSandiBaru" class="form-control bg-transparent border-0 text-white px-3 py-3" style="box-shadow: none;" placeholder="Ulangi kata sandi baru" autocomplete="new-password" />
                            <span class="px-3 toggle-password d-flex align-items-center justify-content-center" style="cursor: pointer; color: var(--text-muted);">
                                <i class="ph ph-eye-slash fs-5"></i>
                            </span>
                        </div>
                        <span asp-validation-for="KonfirmasiKataSandiBaru" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <button type="submit" class="btn btn-gold w-100 py-3 rounded-pill mb-4 shadow-lg tracking-wider text-uppercase small fw-bold">Simpan Kata Sandi Baru</button>
                    
                    <div class="text-center text-light small">
                        <a asp-action="Masuk" class="text-gold fw-bold text-decoration-none d-inline-flex align-items-center gap-2">
                            <i class="ph ph-arrow-left fs-6"></i> Batal & Kembali ke Masuk
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.toggle-password').click(function() {
                var icon = $(this).find('i');
                var input = $(this).siblings('input');
                if (input.attr('type') === 'password' || !input.attr('type')) {
                    input.attr('type', 'text');
                    icon.removeClass('ph-eye-slash').addClass('ph-eye');
                } else {
                    input.attr('type', 'password');
                    icon.removeClass('ph-eye').addClass('ph-eye-slash');
                }
            });

            $('input[name="KataSandiBaru"], input[name="KonfirmasiKataSandiBaru"]').on('focus', function() {
                $(this).closest('.input-group').css({
                    'border-bottom': '2px solid var(--gold)',
                    'background': 'rgba(255, 255, 255, 0.06)'
                });
            }).on('blur', function() {
                $(this).closest('.input-group').css({
                    'border-bottom': '1px solid transparent',
                    'background': 'rgba(255, 255, 255, 0.03)'
                });
            });
        });
    </script>
</body>
</html>
