@{
    ViewData["Title"] = "Akses Eksklusif Dibatasi - Warisan 1948";
}

<div class="container d-flex flex-column justify-content-center align-items-center min-vh-100 py-5">
    <div class="card border-0 shadow-lg p-5 text-center max-w-md w-100 rounded-4" style="background: var(--surface); border: 1px solid var(--border-subtle) !important; backdrop-filter: blur(20px);">
        <div class="mb-4 d-flex justify-content-center">
            <div class="d-flex justify-content-center align-items-center rounded-circle" style="width: 80px; height: 80px; background: rgba(245, 210, 113, 0.1); border: 1px solid var(--gold-glow);">
                <i class="ph ph-shield-warning" style="font-size: 2.75rem; color: var(--gold);"></i>
            </div>
        </div>
        
        <span class="badge rounded-pill px-3 py-2 font-monospace tracking-widest text-uppercase mb-3 mx-auto" style="background: rgba(245, 210, 113, 0.15); color: var(--gold); border: 1px solid var(--gold-glow); font-size: 0.75rem;">
            Keamanan Tingkat Eksekutif
        </span>

        <h2 class="fw-bolder mb-3 text-main tracking-tight" style="font-size: clamp(1.5rem, 4vw, 2.25rem);">
            Akses Dibatasi
        </h2>

        <p class="text-muted mb-4 mx-auto" style="max-width: 420px; font-size: 0.95rem; line-height: 1.6;">
            Halaman atau fitur yang Anda tuju membutuhkan hak akses khusus atau otentikasi peran (Customer / Eksekutif Admin).
            @if (ViewBag.ReturnUrl != null)
            {
                <br /><br />
                <span class="font-monospace small text-main" style="opacity: 0.8;">Tujuan: @ViewBag.ReturnUrl</span>
            }
        </p>

        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center mt-2">
            <a asp-controller="Otentikasi" asp-action="Masuk" class="btn btn-gold px-4 py-3 rounded-pill fw-bold text-uppercase tracking-wider shadow-sm d-inline-flex align-items-center justify-content-center gap-2" style="color: #000 !important;">
                <i class="ph ph-fingerprint fs-5"></i> Masuk dengan Akun Sesuai
            </a>
            <a asp-controller="Beranda" asp-action="Index" class="btn btn-outline-secondary px-4 py-3 rounded-pill fw-semibold text-main d-inline-flex align-items-center justify-content-center gap-2" style="border-color: var(--border-subtle);">
                <i class="ph ph-house fs-5"></i> Kembali ke Beranda
            </a>
        </div>
    </div>
</div>
