@model OT.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Penyelesaian Transaksi (Checkout)";
}

<div class="container py-5" style="margin-top: 80px;">
    <div class="mb-5 text-center scroll-reveal">
        <span class="text-gold fw-bold text-uppercase tracking-wider small mb-2 d-block">Keamanan & Presisi</span>
        <h1 class="fw-bolder tracking-tight mb-2" style="font-size: 2.75rem;">Konfirmasi Mahakarya Pilihan Anda</h1>
        <p class="text-muted small mx-auto" style="max-width: 600px;">
            Pastikan seluruh rincian pesanan dan metode pembayaran eksklusif Anda telah sesuai sebelum memproses transaksi.
        </p>
    </div>

    @if (Model.DaftarItem == null || !Model.DaftarItem.Any())
    {
        <div class="card p-5 text-center border-0 rounded-4 bg-surface scroll-reveal shadow-lg" style="border-radius: 24px;">
            <div class="mb-4 text-muted">
                <i class="ph ph-shopping-cart" style="font-size: 4rem; opacity: 0.3;"></i>
            </div>
            <h3 class="fw-bold mb-2 text-main">Keranjang Belanja Masih Kosong</h3>
            <p class="text-muted mb-4 small">Silakan kembali ke katalog untuk memilih mahakarya 1948 pilihan Anda.</p>
            <div>
                <a asp-controller="Beranda" asp-action="Index" class="btn btn-gold rounded-pill px-5 py-3 tracking-wider text-uppercase small">
                    <i class="ph ph-arrow-left me-2"></i> Eksplorasi Katalog
                </a>
            </div>
        </div>
    }
    else
    {
        <form method="post" asp-action="ProsesQris" asp-controller="Checkout" id="form-checkout">
            @Html.AntiForgeryToken()
            <div class="checkout-grid scroll-reveal" style="display: grid; grid-template-columns: 1fr; gap: 32px;">
                                <div class="checkout-left bg-surface p-4 p-md-5" style="border-radius: 24px; border: 1px solid rgba(255, 255, 255, 0.04); box-shadow: 0 24px 48px rgba(0,0,0,0.45);">
                    <div class="d-flex align-items-center justify-content-between mb-4 border-bottom border-secondary border-opacity-25 pb-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="d-flex align-items-center justify-content-center rounded-circle bg-dark text-gold border border-secondary border-opacity-50" style="width: 44px; height: 44px;">
                                <i class="ph ph-list-checks fs-4"></i>
                            </div>
                            <div>
                                <h4 class="fw-bold mb-0 tracking-tight text-main">Ringkasan Pesanan</h4>
                                <span class="text-muted small">Daftar item mahakarya dalam keranjang Anda</span>
                            </div>
                        </div>
                        <span class="badge rounded-pill bg-dark border border-secondary text-gold px-3 py-2 small">
                            @Model.DaftarItem.Count Mahakarya
                        </span>
                    </div>

                                        <div class="item-list d-flex flex-column gap-3 mb-4">
                        @foreach (var item in Model.DaftarItem)
                        {
                            var subtotalItem = item.HargaSatuan * item.Kuantitas;
                            <div class="item-card d-flex align-items-center justify-content-between p-3 rounded-4 bg-dark bg-opacity-50 border border-secondary border-opacity-25" style="transition: transform 0.3s ease, border-color 0.3s ease;">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="item-thumb rounded-3 overflow-hidden bg-dark d-flex align-items-center justify-content-center position-relative flex-shrink-0" style="width: 72px; height: 72px; border: 1px solid rgba(255,255,255,0.06);">
                                        @if (item.Produk != null && !string.IsNullOrEmpty(item.Produk.JalurGambar))
                                        {
                                            <img src="@(item.Produk.JalurGambar.Replace("/assets/image/", "/assets/webp/").Replace("/OT-Product/webp/", "/assets/webp/"))" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" alt="@(item.Produk?.NamaProduk ?? "Produk OT")" class="w-100 h-100 object-fit-contain p-1" />
                                            <div class="w-100 h-100 align-items-center justify-content-center" style="display: none;"><i class="ph ph-wine fs-3 text-gold"></i></div>
                                        }
                                        else
                                        {
                                            <i class="ph ph-wine fs-3 text-gold"></i>
                                        }
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-1 tracking-tight text-main">@(item.Produk?.NamaProduk ?? "Mahakarya OT 1948")</h6>
                                        <div class="d-flex align-items-center gap-2 small text-muted mb-2">
                                            <span class="font-monospace">@item.HargaSatuan.ToString("C", new System.Globalization.CultureInfo("id-ID"))</span>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <button type="button" class="btn btn-sm btn-outline-secondary rounded-circle d-flex align-items-center justify-content-center btn-update-cart p-0" data-id="@item.ProdukId" data-action="Kurang" style="width: 26px; height: 26px; border-color: var(--border-subtle);"><i class="ph ph-minus small"></i></button>
                                            <span class="badge rounded-pill bg-secondary bg-opacity-25 text-gold font-monospace px-3 py-1">@item.Kuantitas Unit</span>
                                            <button type="button" class="btn btn-sm btn-outline-secondary rounded-circle d-flex align-items-center justify-content-center btn-update-cart p-0" data-id="@item.ProdukId" data-action="Tambah" style="width: 26px; height: 26px; border-color: var(--border-subtle);"><i class="ph ph-plus small"></i></button>
                                            <button type="button" class="btn btn-sm btn-outline-danger rounded-circle d-flex align-items-center justify-content-center btn-update-cart ms-2 p-0" data-id="@item.ProdukId" data-action="Hapus" title="Hapus Item" style="width: 26px; height: 26px;"><i class="ph ph-trash small"></i></button>
                                        </div>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <span class="text-muted small d-block" style="font-size: 0.75rem;">Subtotal</span>
                                    <span class="fw-bold text-gold font-monospace fs-6">@subtotalItem.ToString("C", new System.Globalization.CultureInfo("id-ID"))</span>
                                </div>
                            </div>
                        }
                    </div>

                                        <div class="p-4 rounded-4 bg-dark bg-opacity-75 border border-secondary border-opacity-25 mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2 small text-muted">
                            <span>Subtotal Belanja (@Model.DaftarItem.Sum(i => i.Kuantitas) unit)</span>
                            <span>@Model.TotalHarga.ToString("C", new System.Globalization.CultureInfo("id-ID"))</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-2 small text-muted">
                            <span>Biaya Pengemasan Presisi (Keamanan Taktil)</span>
                            <span class="text-success fw-medium">Gratis (Kehormatan OT)</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-3 small text-muted">
                            <span>Saldo Poin Loyalitas Anda Saat Ini</span>
                            <span class="text-gold fw-semibold">@Model.SaldoPoinLoyalitas Poin</span>
                        </div>
                        <hr class="border-secondary opacity-25 my-3" />
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span class="fw-bold text-main d-block tracking-tight fs-5">Total Harga Transaksi</span>
                                <span class="text-muted small">Termasuk PPN & Asuransi Pengiriman 100%</span>
                            </div>
                            <div class="text-end">
                                <span class="fw-bolder" style="font-size: 2rem; color: var(--gold, #D4AF37); letter-spacing: -0.04em;">
                                    @Model.TotalHarga.ToString("C", new System.Globalization.CultureInfo("id-ID"))
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-2 small text-muted">
                        <i class="ph ph-shield-check text-gold fs-5"></i>
                        <span>Enkripsi SSL 256-bit & Jaminan Keaslian Produk Warisan 1948 langsung dari penyulingan resmi.</span>
                    </div>
                </div>

                                <div class="checkout-right d-flex flex-column gap-4">
                    <div class="bg-surface p-4 p-md-5" style="border-radius: 24px; border: 1px solid rgba(255, 255, 255, 0.04); box-shadow: 0 24px 48px rgba(0,0,0,0.45);">
                        <div class="d-flex align-items-center gap-3 mb-4 border-bottom border-secondary border-opacity-25 pb-3">
                            <div class="d-flex align-items-center justify-content-center rounded-circle bg-dark text-gold border border-secondary border-opacity-50" style="width: 44px; height: 44px;">
                                <i class="ph ph-credit-card fs-4"></i>
                            </div>
                            <div>
                                <h4 class="fw-bold mb-0 tracking-tight">Metode Pembayaran</h4>
                                <span class="text-muted small">Pilih jalur pembayaran instan & aman</span>
                            </div>
                        </div>

                                                <div class="payment-option p-4 rounded-4 mb-3 position-relative" style="background: rgba(212, 175, 55, 0.08); border: 2px solid var(--gold, #D4AF37); border-radius: 16px; cursor: pointer; transition: transform 0.3s ease, box-shadow 0.3s ease; box-shadow: 0 8px 24px rgba(212, 175, 55, 0.15);">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="d-flex align-items-center justify-content-center rounded-3 bg-dark text-gold p-2 border border-secondary border-opacity-50" style="width: 48px; height: 48px;">
                                        <i class="ph ph-qr-code fs-3"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-0 text-main d-flex align-items-center gap-2">
                                            QRIS Nasional
                                            <i class="ph ph-check-circle-fill text-gold fs-5"></i>
                                        </h6>
                                        <span class="text-muted small">Scan instan via BCA, Mandiri, BRI, GoPay, OVO, DANA</span>
                                    </div>
                                </div>
                                <div class="form-check m-0">
                                    <input class="form-check-input" type="radio" name="MetodePembayaranPilihan" id="qris" value="QRIS" checked style="cursor: pointer; background-color: var(--gold); border-color: var(--gold);" />
                                </div>
                            </div>
                            <div class="mt-3 pt-3 border-top border-secondary border-opacity-25 d-flex align-items-center justify-content-between small text-muted">
                                <span>Verifikasi otomatis real-time (0 detik)</span>
                                <span class="badge bg-success bg-opacity-25 text-success rounded-pill px-2 py-1">Rekomendasi Utama</span>
                            </div>
                        </div>

                                                                        <div class="payment-option p-3 rounded-4 mb-3 position-relative" style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px; opacity: 0.5; pointer-events: none;">
                            <div class="position-absolute top-0 end-0 m-3">
                                <span class="badge rounded-pill" style="background-color: #ffcccc; color: #800000; font-size: 0.7rem; font-weight: 700; padding: 4px 10px;">
                                    Sedang Pemeliharaan
                                </span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <div class="d-flex align-items-center justify-content-center rounded-3 bg-dark text-muted p-2" style="width: 44px; height: 44px;">
                                    <i class="ph ph-wallet fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="fw-semibold mb-0 text-main">GoPay Wallet Instan</h6>
                                    <span class="text-muted small">Dompet digital ekosistem GoTo</span>
                                </div>
                            </div>
                        </div>

                                                <div class="payment-option p-3 rounded-4 mb-3 position-relative" style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px; opacity: 0.5; pointer-events: none;">
                            <div class="position-absolute top-0 end-0 m-3">
                                <span class="badge rounded-pill" style="background-color: #fff2cc; color: #806000; font-size: 0.7rem; font-weight: 700; padding: 4px 10px;">
                                    Sedang Pemeliharaan
                                </span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <div class="d-flex align-items-center justify-content-center rounded-3 bg-dark text-muted p-2" style="width: 44px; height: 44px;">
                                    <i class="ph ph-device-mobile fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="fw-semibold mb-0 text-main">OVO Cash & Points</h6>
                                    <span class="text-muted small">Pembayaran cepat satu sentuhan</span>
                                </div>
                            </div>
                        </div>

                                                <div class="payment-option p-3 rounded-4 mb-4 position-relative" style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px; opacity: 0.5; pointer-events: none;">
                            <div class="position-absolute top-0 end-0 m-3">
                                <span class="badge rounded-pill" style="background-color: #ffcccc; color: #800000; font-size: 0.7rem; font-weight: 700; padding: 4px 10px;">
                                    Sedang Pemeliharaan
                                </span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <div class="d-flex align-items-center justify-content-center rounded-3 bg-dark text-muted p-2" style="width: 44px; height: 44px;">
                                    <i class="ph ph-currency-circle-dollar fs-4"></i>
                                </div>
                                <div>
                                    <h6 class="fw-semibold mb-0 text-main">DANA Dompet Digital</h6>
                                    <span class="text-muted small">Transaksi tanpa potongan biaya</span>
                                </div>
                            </div>
                        </div>

                                                <button type="submit" class="btn btn-gold w-100 py-3 rounded-pill fw-bold text-uppercase tracking-wider shadow-lg d-flex align-items-center justify-content-center gap-2" style="border-radius: 12px !important; font-size: 1rem;">
                            <i class="ph ph-lock-key fs-5"></i>
                            <span>Konfirmasi & Bayar QRIS</span>
                        </button>
                        
                        <div class="text-center mt-3 small text-muted">
                            Dengan mengklik tombol di atas, Anda menyetujui Ketentuan Layanan & Kebijakan Keaslian Produk Orang Tua 1948.
                        </div>
                    </div>
                </div>
            </div>
        </form>
    }
</div>

<style>
    @@media (min-width: 992px) {
        .checkout-grid {
            grid-template-columns: 3fr 2fr !important;
        }
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.btn-update-cart').click(function(e) {
                e.preventDefault();
                var btn = $(this);
                var id = btn.data('id');
                var action = btn.data('action');
                var url = '/Keranjang/' + action;
                
                btn.prop('disabled', true);
                $.post(url, { produkId: id }, function(res) {
                    if (res.sukses) {
                        window.location.reload();
                    } else {
                        alert(res.pesan || 'Terjadi kesalahan');
                        btn.prop('disabled', false);
                    }
                });
            });
        });
    </script>
}
